dist/vision_server/
build/*.egg-info/

# ── Electron build output ─────────────────────────────────────────────────────
dist/
out/
.electron/

# ── Runtime data (never commit) ───────────────────────────────────────────────
data/
logs/
*.log

# ── Screenshots / recordings (binary blobs) ───────────────────────────────────
screenshots/
recordings/
*.png.bak

# ── Environment / secrets ─────────────────────────────────────────────────────
.env
.env.local
.env.*.local
config/local.json

# ── OS ────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
ehthumbs.db

