{
  "name": "gamepartner",
  "version": "0.1.0",
  "description": "Local-first AI gaming companion",
  "main": "src/launcher/main.js",
  "scripts": {
    "start":       "electron .",
    "dev":         "electron . --dev",
    "build:vision": "pyinstaller build/vision_service.spec --distpath dist/ --noconfirm",
    "dist":        "npm run build:vision && electron-builder --win --x64",
    "build":       "electron-builder --win --x64",
    "pack":        "electron-builder --dir",
    "test":           "node tests/test_normalizer.js && node tests/test_decision_engine.js",
    "test:normalizer": "node tests/test_normalizer.js",
    "test:decisions":  "node tests/test_decision_engine.js",
    "test:python":     "python tests/test_vision_pipeline.py",
    "test:all":        "node tests/test_normalizer.js && node tests/test_decision_engine.js && python tests/test_vision_pipeline.py"
  },
  "dependencies": {
    "better-sqlite3":  "^9.4.3",
    "electron-log":    "^5.1.2",
    "electron-updater": "^6.1.8",
    "express":         "^4.18.3",
    "ws":              "^8.16.0"
  },
  "devDependencies": {
    "electron":         "^29.1.1",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId":       "com.gamepartner.app",
    "productName": "GamePartner",
    "win": {
      "target": "nsis",
      "icon":   "assets/sprite.png"
    },
    "nsis": {
      "oneClick":                        true,
      "perMachine":                      false,
      "deleteAppDataOnUninstall":        false,
      "createDesktopShortcut":           true,
      "createStartMenuShortcut":         true,
      "shortcutName":                    "GamePartner"
    },
    "files": [
      "src/**/*",
      "config/**/*",
      "assets/**/*",
      "!src/services/vision/**/*"
    ],
    "extraResources": [
      {
        "from":   "dist/vision_server",
        "to":     "vision",
        "filter": ["**/*"]
      }
    ],
    "publish": {
      "provider": "github",
      "owner":    "Zwin-ux",
      "repo":     "botbot2"
    },
    "directories": {
      "output": "dist/installer"
    }
  }
}
