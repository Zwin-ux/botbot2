{
  "name": "Minesweeper",
  "game": "minesweeper",
  "version": "1.1.0",
  "resolution": [1920, 1080],
  "maxDecisionsPerFrame": 1,

  "_calibration_notes": [
    "ROIs assume classic Minesweeper (Expert board) centered on a 1920x1080 screen.",
    "Window approx 500x360px, centered at ~(710, 360).",
    "If your Minesweeper window is in a different position, use:",
    "  python tools/calibrate_rois.py --capture",
    "to recalibrate the ROI pixel coordinates below.",
    "Microsoft Store Minesweeper has a different layout — these ROIs target the",
    "classic Win7-style Minesweeper or open-source clones (e.g. Mines, Gnome Mines)."
  ],

  "hud": {
    "health": {
      "roi": [726, 376, 78, 32],
      "method": "ocr_number",
      "range": [0, 999],
      "_label": "mines remaining counter (top-left of Minesweeper header bar)"
    },
    "credits": {
      "roi": [1118, 376, 78, 32],
      "method": "ocr_number",
      "range": [0, 999],
      "_label": "timer seconds (top-right of Minesweeper header bar)"
    },
    "phase": {
      "roi": [936, 372, 40, 40],
      "method": "face_state",
      "_label": "game state face button (center of Minesweeper header bar)"
    }
  },

  "rules": [
    {
      "id": "almost_done",
      "trigger": "health.change",
      "condition": { "payload.current": { "$lte": 3, "$gt": 0 } },
      "priority": "medium",
      "cooldown": 30000,
      "confidence": { "minSignals": 2, "window": 3000 },
      "output": {
        "message": "Almost done -- scan edges carefully",
        "ttl": 8000
      }
    },
    {
      "id": "halfway_done",
      "trigger": "health.change",
      "condition": { "payload.current": { "$lte": 10, "$gt": 3 } },
      "priority": "low",
      "cooldown": 60000,
      "confidence": { "minSignals": 2, "window": 3000 },
      "output": {
        "message": "Good progress -- stay focused",
        "ttl": 5000
      }
    },
    {
      "id": "taking_long",
      "trigger": "economy.credits",
      "condition": { "payload.amount": { "$gte": 180 } },
      "priority": "low",
      "cooldown": 60000,
      "confidence": { "minSignals": 2, "window": 3000 },
      "output": {
        "message": "3 min in -- look for number patterns",
        "ttl": 6000
      }
    },
    {
      "id": "speed_run",
      "trigger": "economy.credits",
      "condition": { "payload.amount": { "$lte": 30 } },
      "priority": "info",
      "cooldown": 90000,
      "confidence": { "minSignals": 2, "window": 3000 },
      "output": {
        "message": "Speed run pace -- nice",
        "ttl": 4000
      }
    },
    {
      "id": "game_lost",
      "trigger": "round.buy_phase",
      "condition": { "payload.credits": { "$eq": -1 } },
      "priority": "high",
      "cooldown": 5000,
      "confidence": { "minSignals": 1, "window": 2000 },
      "output": {
        "message": "Boom! Try again",
        "ttl": 6000
      }
    }
  ]
}
